{
  "homepage": "https://ui.crossplatformkorea.com",
  "publishConfig": {
    "access": "public"
  },
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "predeploy": "bun run build",
    "postinstall": "node bin/greeting.js",
    "pack:dry": "bun run build && npm pack --dry-run ./lib",
    "lint": "eslint .",
    "lint:ci": "commitlint --from HEAD~0 --to HEAD --verbose",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "storybook:web": "storybook dev -p 6006",
    "build-storybook": "STORYBOOK=1 storybook build",
    "storybook-generate": "sb-rn-get-stories --config-path .ondevice",
    "storybook:audit:ios": "node scripts/audit-native-storybook.js --platform ios",
    "storybook:audit:android": "node scripts/audit-native-storybook.js --platform android",
    "storybook:check": "node scripts/check-story-coverage.js",
    "components:check": "node scripts/check-component-coverage.js",
    "storybook": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start",
    "storybook:ios": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start --ios",
    "storybook:android": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start --android",
    "tsc": "tsc",
    "start:reset": "watchman watch-del-all && lsof -t -i :8081 | xargs kill && expo start -c",
    "jest": "jest --runInBand",
    "check-peer-deps": "node scripts/check-peer-deps.js",
    "e2e-smoke": "node scripts/e2e-smoke.js",
    "test:all": "bun run lint && bun run components:check && bun run storybook:check && bun run tsc && bun run test",
    "prebuild": "find ./lib -mindepth 1 ! -name 'package.json' -exec rm -rf {} +",
    "build": "tsc --project tsconfigBuild.json && cpx './src/**/*.{ts,tsx}' ./lib/src/",
    "postbuild": "cp ./src/react-native.config.cjs ./lib/react-native.config.cjs && rm -rf ./lib/tsconfig* && cp README.md ./lib/README.md && mkdir -p ./lib/components/uis/Icon && find ./src/components/uis/Icon/ -type f \\( -name '*.otf' -o -name '*.ttf' \\) -exec cp {} ./lib/components/uis/Icon/ \\;",
    "storybook:build": "storybook build --docs -o ./doc-build -c ./.storybook",
    "storybook:serve": "npx http-server ./doc-build",
    "export": "expo export -p web",
    "deploy:storybook": "gh-pages -t -d dist",
    "prepare": "husky && husky install"
  },
  "dependencies": {
    "@expo/match-media": "^0.4.0",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-screen-orientation": "~9.0.9",
    "expo-status-bar": "~3.0.9",
    "kstyled": "0.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-responsive": "^10.0.1",
    "react-useinterval": "^1.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@chromatic-com/storybook": "^3.2.3",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@expo/metro-runtime": "~6.1.2",
    "@jest/types": "^29.6.3",
    "@storybook/addon-a11y": "8.6.14",
    "@storybook/addon-actions": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-links": "^8.4.7",
    "@storybook/addon-ondevice-actions": "^8.4.3",
    "@storybook/addon-ondevice-backgrounds": "^8.4.3",
    "@storybook/addon-ondevice-controls": "^8.4.3",
    "@storybook/addon-ondevice-notes": "^8.4.3",
    "@storybook/addon-react-native-web": "^0.0.26",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.3",
    "@storybook/blocks": "8.6.14",
    "@storybook/core": "^8.4.7",
    "@storybook/manager-api": "8.6.14",
    "@storybook/react": "^8.4.7",
    "@storybook/react-native": "^8.4.3",
    "@storybook/react-webpack5": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@storybook/theming": "8.6.14",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/jest-plugin-context": "^2.9.7",
    "@types/node": "^20.11.15",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/react-responsive": "^8.0.8",
    "@types/react-test-renderer": "^18.0.7",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "babel-loader": "^9.2.1",
    "babel-plugin-kstyled": "0.4.1",
    "babel-plugin-react-docgen-typescript": "^1.5.1",
    "babel-plugin-react-native-web": "^0.21.2",
    "babel-preset-expo": "~54.0.10",
    "babel-preset-react-app": "^10.1.0",
    "commitlint-plugin-function-rules": "^4.3.2",
    "cpx": "^1.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^0.6.15",
    "gh-pages": "^6.3.0",
    "givens": "^1.3.9",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jest-plugin-context": "^2.9.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.1.0",
    "storybook": "^8.4.7",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "packageManager": "bun@1.3.10"
}
